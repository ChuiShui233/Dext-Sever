# 重命名为.env，并填写真实值

DB_USER=
DB_PASSWORD=
DB_HOST=
DB_NAME=

JWT_EXPIRATION=
PASSWORD_PEPPER=
OPENASSETS_TOKEN=
OPENASSETS_BUCKET=

PORT=
#图形验证码难度 1-3
CAPTCHA_LEVEL=
ENV=production

# CORS 严格白名单（逗号分隔的 Origin 列表；生产环境建议必须填写）
# 示例: https://qs.chuishui.top,https://admin.chuishui.top
CORS_ALLOWED_ORIGINS=

# CSRF 防护模式：off/log/enforce
# - off: 关闭（开发环境默认）
# - log: 仅记录（生产环境默认）
# - enforce: 强制校验（需要前端对每个非 GET 请求带上 X-CSRF-Token，与 csrf_token Cookie 一致）
CSRF_MODE=

# SSL证书配置
HTTPS_ENABLED=
SSL_CERT_FILE=
SSL_KEY_FILE=
HTTPS_PORT=
HTTP_REDIRECT=

# OAuth配置
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# 个推推送配置
GETUI_APP_ID=
GETUI_APP_KEY=
GETUI_APP_SECRET=
GETUI_MASTER_SECRET=

# 邮件服务配置
EMAIL_PROVIDER=
# EMAIL_PROVIDER=resend/smtp

# SMTP配置
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=
SMTP_FROM_EMAIL=

# Resend配置
RESEND_API_KEY=
# 发件地址
RESEND_FROM_EMAIL=
# 回复地址
RESEND_REPLY_TO=

# 匿名用户ID配置（严格检测/端口纳入）
# off: 仅IP；normal: IP+UA+surveyUID+salt；strict: IP+UA+Accept-Language+surveyUID+salt(+端口)
ANON_ID_MODE=
# 严格模式下是否纳入端口（一般不建议）
ANON_INCLUDE_PORT=
# 在有反向代理(Nginx/Caddy)时建议开启，从 X-Forwarded-For 获取真实IP
TRUST_PROXY=
# 可选盐值
ANON_ID_SALT=
# 可信代理列表，逗号分隔（默认为 127.0.0.1）
TRUSTED_PROXIES=

# 回收站清理配置
RECYCLE_BIN_CLEANUP_CRON=0 0 * * *
RECYCLE_BIN_RETENTION_DAYS=30

# OpenAssets 存储后端配置
# ASSETS_BACKEND: local（默认，本地磁盘存储）或 github（GitHub 仓库 + jsDelivr CDN 图床）
# github 模式下：上传时先落本地缓存(assets_storage)再异步推送到 GitHub；
# 下载时优先读本地缓存，未命中则从 jsDelivr CDN 拉取并回填缓存。
# github 模式下 MaxFileSize 自动调整为 25MB。
ASSETS_BACKEND=local

# GitHub 图床配置（ASSETS_BACKEND=github)
# Token 需要 repo 权限（用于 Contents API 增删）
GITHUB_ASSETS_TOKEN=
# GitHub 用户名/组织名
GITHUB_ASSETS_OWNER=
# 仓库名（建议公开仓库以便 jsDelivr 加速）
GITHUB_ASSETS_REPO=
# 分支名，默认 main
GITHUB_ASSETS_BRANCH=main
# jsDelivr CDN 域名，默认 cdn.jsdelivr.net
GITHUB_ASSETS_CDN_DOMAIN=cdn.jsdelivr.net


